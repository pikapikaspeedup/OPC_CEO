{
  "id": "large-project-template",
  "kind": "template",
  "title": "大型项目分解开发",
  "description": "项目规划产出工作包，并行执行子项目，最终汇合集成验证。",
  "pipeline": [
    {
      "stageId": "planning",
      "autoTrigger": false,
      "title": "项目规划",
      "description": "拆解目标并产出工作包清单，供 fan-out 阶段创建子项目。",
      "executionMode": "review-loop",
      "roles": [
        {
          "id": "project-planner",
          "workflow": "/project-planner",
          "timeoutMs": 900000,
          "autoApprove": true
        },
        {
          "id": "product-lead-reviewer",
          "workflow": "/product-lead-reviewer",
          "timeoutMs": 600000,
          "autoApprove": true
        }
      ],
      "capabilities": {
        "acceptsEnvelope": true,
        "emitsManifest": true,
        "advisory": true
      },
      "reviewPolicyId": "default-product",
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    },
    {
      "stageId": "wp-execution",
      "autoTrigger": true,
      "triggerOn": "approved",
      "upstreamStageIds": [
        "planning"
      ],
      "stageType": "fan-out",
      "fanOutSource": {
        "workPackagesPath": "specs/work-packages.json",
        "perBranchTemplateId": "development-template-1"
      },
      "title": "工作包并行执行",
      "description": "编排节点：读取工作包并为每个工作包派发一个子项目。",
      "executionMode": "orchestration",
      "roles": [],
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    },
    {
      "stageId": "convergence",
      "autoTrigger": true,
      "upstreamStageIds": [
        "wp-execution"
      ],
      "stageType": "join",
      "joinFrom": "wp-execution",
      "joinPolicy": "all",
      "title": "汇合关卡",
      "description": "编排节点：等待所有分支完成后推进下游集成验证。",
      "executionMode": "orchestration",
      "roles": [],
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    },
    {
      "stageId": "integration",
      "autoTrigger": true,
      "triggerOn": "completed",
      "upstreamStageIds": [
        "convergence"
      ],
      "title": "集成验证",
      "description": "在主工作区执行端到端集成验证，并输出最终结果。",
      "executionMode": "legacy-single",
      "roles": [
        {
          "id": "integration-tester",
          "workflow": "/integration-tester",
          "timeoutMs": 1200000,
          "autoApprove": true
        }
      ],
      "capabilities": {
        "acceptsEnvelope": true,
        "emitsManifest": true
      },
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    }
  ],
  "defaultModel": "MODEL_PLACEHOLDER_M26"
}

{
  "id": "graph-smoke-template",
  "kind": "template",
  "title": "V5 Graph Pipeline Smoke",
  "description": "Minimal E2E test for graphPipeline: planning → fan-out → join → integration.",
  "graphPipeline": {
    "nodes": [
      {
        "id": "planning",
        "kind": "stage",
        "autoTrigger": true,
        "title": "Smoke Planning",
        "description": "Seeds a deterministic work package file.",
        "executionMode": "legacy-single",
        "roles": [
          {
            "id": "smoke-work-package-seeder",
            "workflow": "/smoke-work-package-seeder",
            "timeoutMs": 300000,
            "autoApprove": true
          }
        ],
        "capabilities": {
          "acceptsEnvelope": true,
          "emitsManifest": true
        },
        "defaultModel": "MODEL_PLACEHOLDER_M37"
      },
      {
        "id": "fanout",
        "kind": "fan-out",
        "triggerOn": "completed",
        "fanOut": {
          "workPackagesPath": "delivery/work-packages.json",
          "perBranchTemplateId": "v4-smoke-branch-template"
        },
        "title": "Smoke Fan-Out",
        "description": "Orchestration node that creates child projects from the seeded work packages.",
        "executionMode": "orchestration",
        "roles": [],
        "defaultModel": "MODEL_PLACEHOLDER_M37"
      },
      {
        "id": "join",
        "kind": "join",
        "join": {
          "sourceNodeId": "fanout",
          "policy": "all"
        },
        "title": "Smoke Join",
        "description": "Orchestration node that waits for all branches to complete.",
        "executionMode": "orchestration",
        "roles": [],
        "defaultModel": "MODEL_PLACEHOLDER_M37"
      },
      {
        "id": "integration",
        "kind": "stage",
        "triggerOn": "completed",
        "title": "Smoke Integration",
        "description": "Final smoke report after join completes.",
        "executionMode": "legacy-single",
        "roles": [
          {
            "id": "smoke-integration-check",
            "workflow": "/smoke-integration-check",
            "timeoutMs": 300000,
            "autoApprove": true
          }
        ],
        "capabilities": {
          "acceptsEnvelope": true,
          "emitsManifest": true
        },
        "defaultModel": "MODEL_PLACEHOLDER_M37"
      }
    ],
    "edges": [
      {
        "from": "planning",
        "to": "fanout"
      },
      {
        "from": "fanout",
        "to": "join"
      },
      {
        "from": "join",
        "to": "integration"
      }
    ]
  },
  "defaultModel": "MODEL_PLACEHOLDER_M37"
}

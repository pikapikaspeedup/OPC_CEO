{
  "id": "v4-smoke-template",
  "kind": "template",
  "title": "V4 Fan-Out Smoke",
  "description": "A minimal orchestration smoke test for planning, fan-out, join, and integration.",
  "pipeline": [
    {
      "stageId": "planning",
      "autoTrigger": false,
      "title": "Smoke Planning",
      "description": "Seeds a deterministic work package file.",
      "executionMode": "legacy-single",
      "roles": [
        {
          "id": "smoke-work-package-seeder",
          "workflow": "/smoke-work-package-seeder",
          "timeoutMs": 300000,
          "autoApprove": true
        }
      ],
      "capabilities": {
        "acceptsEnvelope": true,
        "emitsManifest": true
      },
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    },
    {
      "stageId": "fanout",
      "autoTrigger": true,
      "triggerOn": "completed",
      "upstreamStageIds": [
        "planning"
      ],
      "stageType": "fan-out",
      "fanOutSource": {
        "workPackagesPath": "delivery/work-packages.json",
        "perBranchTemplateId": "v4-smoke-branch-template"
      },
      "title": "Smoke Fan-Out",
      "description": "Orchestration node that creates child projects from the seeded work packages.",
      "executionMode": "orchestration",
      "roles": [],
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    },
    {
      "stageId": "join",
      "autoTrigger": true,
      "upstreamStageIds": [
        "fanout"
      ],
      "stageType": "join",
      "joinFrom": "fanout",
      "joinPolicy": "all",
      "title": "Smoke Join",
      "description": "Orchestration node that waits for all branches to complete.",
      "executionMode": "orchestration",
      "roles": [],
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    },
    {
      "stageId": "integration",
      "autoTrigger": true,
      "triggerOn": "completed",
      "upstreamStageIds": [
        "join"
      ],
      "title": "Smoke Integration",
      "description": "Final smoke report after join completes.",
      "executionMode": "legacy-single",
      "roles": [
        {
          "id": "smoke-integration-check",
          "workflow": "/smoke-integration-check",
          "timeoutMs": 300000,
          "autoApprove": true
        }
      ],
      "capabilities": {
        "acceptsEnvelope": true,
        "emitsManifest": true
      },
      "defaultModel": "MODEL_PLACEHOLDER_M26"
    }
  ],
  "defaultModel": "MODEL_PLACEHOLDER_M26"
}

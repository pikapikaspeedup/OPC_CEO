{
  "id": "v4-smoke-branch-template",
  "kind": "template",
  "title": "V4 Smoke Branch",
  "description": "A minimal child template used to validate fan-out branch execution.",
  "groups": {
    "smoke-branch-task": {
      "title": "Smoke Branch Task",
      "description": "A trivial child stage that completes quickly.",
      "executionMode": "legacy-single",
      "capabilities": { "acceptsEnvelope": true, "emitsManifest": true },
      "roles": [
        { "id": "smoke-branch-worker", "workflow": "/smoke-branch-worker", "timeoutMs": 300000, "autoApprove": true }
      ]
    }
  },
  "pipeline": [
    {
      "stageId": "branch-task",
      "groupId": "smoke-branch-task",
      "autoTrigger": false
    }
  ],
  "defaultModel": "MODEL_PLACEHOLDER_M26"
}
